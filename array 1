#include <stdio.h>

int main() {
    int n, i;
    int smallest, second;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[n];

    printf("Enter elements:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    smallest = second = 99999;

    for(i = 0; i < n; i++) {
        if(arr[i] < smallest) {
            second = smallest;
            smallest = arr[i];
        }
        else if(arr[i] < second && arr[i] != smallest) {
            second = arr[i];
        }
    }

    printf("Second smallest element is: %d\n", second);

    return 0;
}
